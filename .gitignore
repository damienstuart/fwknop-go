# .gitignore for golang projects.
###############################################################################
# Binaries
*.exe
*.o

# Test binaries
*.test

# Dependencies (Go modules)
/vendor/

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo

# Mac/OSX
.DS_Store

# Windows
Thumbs.db

# Coverage files
*.out

# Temporary files
*~
*-

# Any tmp dir
tmp/
temp/

# log files
*.log

# Env files
.env
*.env

### Project-specific

# The generated dirs and files
bin/
_notes/

# Claude Code
CLAUDE.md
.claude/